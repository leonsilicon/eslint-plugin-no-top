{
  "name": "eslint-plugin-no-top",
  "version": "0.1.0",
  "description": "Disallow side effects at the top level of files",
  "keywords": [
    "eslint",
    "eslint-plugin",
    "eslintplugin",
    "no-top",
    "side-effects"
  ],
  "homepage": "https://github.com/leonsilicon/eslint-plugin-no-top#readme",
  "bugs": {
    "url": "https://github.com/leonsilicon/eslint-plugin-no-top/issues"
  },
  "license": "ISC",
  "author": "Leon Si <leon@leonsilicon.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leonsilicon/eslint-plugin-no-top.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@types/estree": "^1.0.9",
    "@types/node": "^25.6.2",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "bumpp": "^11.1.0",
    "eslint": "^10.4.1",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.20"
  },
  "peerDependencies": {
    "eslint": ">=9"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.14"
}
